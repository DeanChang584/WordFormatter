<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WordFormatterUI.Pages.ProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="Page_Loaded">

    <Grid Padding="24,16,24,16" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock
            Style="{StaticResource TitleTextBlockStyle}"
            Text="排版配置" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="20" Padding="0,0,8,0">

                <!-- Page Settings Card -->
                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="页面设置" />
                <StackPanel Spacing="8" Padding="16" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <Grid ColumnSpacing="12" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock VerticalAlignment="Center" Text="纸张大小" />
                        <ComboBox Grid.Column="1" x:Name="PaperSizeBox" SelectionChanged="Field_Changed" />
                        <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="上边距 (mm)" />
                        <NumberBox Grid.Column="1" Grid.Row="1" x:Name="MarginTopBox" ValueChanged="NumberBox_Changed" />
                        <TextBlock Grid.Row="2" VerticalAlignment="Center" Text="下边距 (mm)" />
                        <NumberBox Grid.Column="1" Grid.Row="2" x:Name="MarginBottomBox" ValueChanged="NumberBox_Changed" />
                        <TextBlock Grid.Row="3" VerticalAlignment="Center" Text="左边距 (mm)" />
                        <NumberBox Grid.Column="1" Grid.Row="3" x:Name="MarginLeftBox" ValueChanged="NumberBox_Changed" />
                    </Grid>
                </StackPanel>

                <!-- Body Style Card -->
                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="正文样式" />
                <StackPanel Spacing="8" Padding="16" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <Grid ColumnSpacing="12" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock VerticalAlignment="Center" Text="中文字体" />
                        <TextBox Grid.Column="1" x:Name="FontCnBox" TextChanged="Field_Changed" />
                        <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="英文字体" />
                        <TextBox Grid.Column="1" Grid.Row="1" x:Name="FontEnBox" TextChanged="Field_Changed" />
                        <TextBlock Grid.Row="2" VerticalAlignment="Center" Text="字号 (pt)" />
                        <NumberBox Grid.Column="1" Grid.Row="2" x:Name="FontSizeBox" ValueChanged="NumberBox_Changed" />
                    </Grid>
                </StackPanel>

                <!-- Paragraph Style Card -->
                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="段落格式" />
                <StackPanel Spacing="8" Padding="16" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <Grid ColumnSpacing="12" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock VerticalAlignment="Center" Text="行距倍数" />
                        <NumberBox Grid.Column="1" x:Name="LineSpacingBox" ValueChanged="NumberBox_Changed" />
                        <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="首行缩进 (mm)" />
                        <NumberBox Grid.Column="1" Grid.Row="1" x:Name="IndentBox" ValueChanged="NumberBox_Changed" />
                        <TextBlock Grid.Row="2" VerticalAlignment="Center" Text="对齐方式" />
                        <ComboBox Grid.Column="1" Grid.Row="2" x:Name="AlignmentBox" SelectionChanged="Field_Changed" />
                    </Grid>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer with Save -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" Padding="0,8,0,0">
            <Button
                x:Name="SaveBtn"
                Click="Save_Click"
                Content="保存配置"
                IsEnabled="False"
                Style="{StaticResource AccentButtonStyle}" />
            <TextBlock
                x:Name="StatusText"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>
    </Grid>
</Page>