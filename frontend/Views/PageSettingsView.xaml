<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WordFormatterUI.Views.PageSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WordFormatterUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:behaviors="using:WordFormatterUI.Behaviors"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Name="ViewRoot">

    <!--
        PageSettingsView: configuration form for page layout (design-document §9.1).
        Wrapped in a ConfigCard with "保存为模板" and "重置为默认值" buttons hidden
        (reset is handled globally by the ProfileViewModel).
    -->
    <controls:ConfigCard Title="页面设置">
        <StackPanel Spacing="8">

            <!-- 纸张大小 -->
            <Grid Height="32" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="纸张大小" />
                <ComboBox
                    Grid.Column="1"
                    x:Name="PaperSizeBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    SelectionChanged="PaperSizeBox_SelectionChanged" />
            </Grid>

            <!-- 文字方向 -->
            <Grid Height="32" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="文字方向" />
                <ComboBox
                    Grid.Column="1"
                    x:Name="OrientationBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    SelectionChanged="OrientationBox_SelectionChanged">
                    <ComboBoxItem Tag="portrait">纵向</ComboBoxItem>
                    <ComboBoxItem Tag="landscape">横向</ComboBoxItem>
                </ComboBox>
            </Grid>

            <!-- 上边距 -->
            <Grid Height="32" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="上边距" />
                <controls:NumericTextBox
                    Grid.Column="1"
                    x:Name="MarginTopBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    ValueChanged="MarginBox_ValueChanged" />
                <ComboBox
                    Grid.Column="2"
                    x:Name="MarginTopUnitBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    SelectedIndex="0"
                    SelectionChanged="MarginUnit_SelectionChanged">
                    <ComboBoxItem>毫米</ComboBoxItem>
                    <ComboBoxItem>厘米</ComboBoxItem>
                </ComboBox>
            </Grid>

            <!-- 下边距 -->
            <Grid Height="32" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="下边距" />
                <controls:NumericTextBox
                    Grid.Column="1"
                    x:Name="MarginBottomBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    ValueChanged="MarginBox_ValueChanged" />
                <ComboBox
                    Grid.Column="2"
                    x:Name="MarginBottomUnitBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    SelectedIndex="0"
                    SelectionChanged="MarginUnit_SelectionChanged">
                    <ComboBoxItem>毫米</ComboBoxItem>
                    <ComboBoxItem>厘米</ComboBoxItem>
                </ComboBox>
            </Grid>

            <!-- 左边距 -->
            <Grid Height="32" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="左边距" />
                <controls:NumericTextBox
                    Grid.Column="1"
                    x:Name="MarginLeftBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    ValueChanged="MarginBox_ValueChanged" />
                <ComboBox
                    Grid.Column="2"
                    x:Name="MarginLeftUnitBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    SelectedIndex="0"
                    SelectionChanged="MarginUnit_SelectionChanged">
                    <ComboBoxItem>毫米</ComboBoxItem>
                    <ComboBoxItem>厘米</ComboBoxItem>
                </ComboBox>
            </Grid>

            <!-- 右边距 -->
            <Grid Height="32" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="右边距" />
                <controls:NumericTextBox
                    Grid.Column="1"
                    x:Name="MarginRightBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    ValueChanged="MarginBox_ValueChanged" />
                <ComboBox
                    Grid.Column="2"
                    x:Name="MarginRightUnitBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    SelectedIndex="0"
                    SelectionChanged="MarginUnit_SelectionChanged">
                    <ComboBoxItem>毫米</ComboBoxItem>
                    <ComboBoxItem>厘米</ComboBoxItem>
                </ComboBox>
            </Grid>

            <!-- ── 文档网格 ──────────────────────────────────────────── -->

            <!-- 文档网格模式 -->
            <Grid Height="32" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="文档网格" />
                <ComboBox
                    Grid.Column="1"
                    x:Name="GridModeBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    SelectionChanged="GridModeBox_SelectionChanged" />
            </Grid>

            <!-- 页面行数 (仅当网格启用时显示) -->
            <Grid
                Height="32"
                ColumnSpacing="8"
                x:Name="LinesPerPageRow"
                Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="页面行数" />
                <controls:NumericTextBox
                    Grid.Column="1"
                    x:Name="LinesPerPageBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    ValueChanged="LinesPerPageBox_ValueChanged" />
            </Grid>

            <!-- 每行字符 (仅当 "指定行和字符网格" 时显示) -->
            <Grid
                Height="32"
                ColumnSpacing="8"
                x:Name="CharsPerLineRow"
                Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="每行字符" />
                <controls:NumericTextBox
                    Grid.Column="1"
                    x:Name="CharsPerLineBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    ValueChanged="CharsPerLineBox_ValueChanged" />
            </Grid>

            <!-- 自动调整右缩进 (仅当网格启用时显示) -->
            <Grid Height="32" x:Name="AdjustRightIndentRow" Visibility="Collapsed">
                <CheckBox
                    x:Name="AdjustRightIndentBox"
                    VerticalAlignment="Center"
                    Content="自动调整右缩进"
                    Checked="AdjustRightIndentBox_Checked"
                    Unchecked="AdjustRightIndentBox_Checked" />
            </Grid>

            <!-- 与网格对齐 (仅当网格启用时显示) -->
            <Grid Height="32" x:Name="AlignToGridRow" Visibility="Collapsed">
                <CheckBox
                    x:Name="AlignToGridBox"
                    VerticalAlignment="Center"
                    Content="与网格对齐"
                    Checked="AlignToGridBox_Checked"
                    Unchecked="AlignToGridBox_Checked" />
            </Grid>

        </StackPanel>
    </controls:ConfigCard>
</UserControl>
