<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WordFormatterUI.Views.PreviewWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="">

    <Grid x:Name="LayoutRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ── Title Bar ─────────────────────────────────────────────── -->
        <Grid
            Grid.Row="0"
            x:Name="TitleBarGrid"
            Background="Transparent"
            Height="32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                Text="PDF 预览"
                VerticalAlignment="Center"
                Margin="12,0,0,0"
                FontSize="12"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <StackPanel
                Grid.Column="1"
                Orientation="Horizontal"
                x:Name="TitleBarButtons">
                <Button
                    x:Name="MinimizeBtn"
                    Content="&#xE921;"
                    FontFamily="Segoe Fluent Icons"
                    FontSize="10"
                    Width="46"
                    Height="32"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="Minimize_Click" />
                <Button
                    x:Name="MaximizeBtn"
                    Content="&#xE922;"
                    FontFamily="Segoe Fluent Icons"
                    FontSize="10"
                    Width="46"
                    Height="32"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="Maximize_Click" />
                <Button
                    x:Name="CloseBtn"
                    Content="&#xE8BB;"
                    FontFamily="Segoe Fluent Icons"
                    FontSize="10"
                    Width="46"
                    Height="32"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="Close_Click" />
            </StackPanel>
        </Grid>

        <!-- ── PDF Viewer / Loading ───────────────────────────────────── -->
        <Grid Grid.Row="1">
            <!-- WebView2 PDF viewer (hidden during loading) -->
            <WebView2
                x:Name="PdfViewer"
                Visibility="Collapsed"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch" />

            <!-- Loading overlay (also used for error display) -->
            <StackPanel
                x:Name="LoadingOverlay"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Spacing="12"
                MaxWidth="480"
                Margin="24,0">
                <ProgressRing
                    x:Name="LoadingRing"
                    IsActive="True"
                    Width="48"
                    Height="48" />
                <TextBlock
                    x:Name="LoadingText"
                    Text="正在生成预览……"
                    FontSize="16"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    HorizontalAlignment="Center"
                    TextWrapping="WrapWholeWords"
                    TextAlignment="Center" />
                <TextBlock
                    x:Name="LoadingSubText"
                    Text="请稍候"
                    FontSize="13"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- ── Bottom Toolbar ─────────────────────────────────────────── -->
        <Grid
            Grid.Row="2"
            x:Name="Toolbar"
            Height="40"
            Padding="12,0"
            ColumnSpacing="6"
            Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" x:Name="Zoom100Btn" Content="100%"
                    Width="48" Height="28" FontSize="11" BorderThickness="0" Click="Zoom100_Click" />
            <Button Grid.Column="1" x:Name="FitWidthBtn" Content="适应宽度"
                    Width="72" Height="28" FontSize="11" BorderThickness="0" Click="FitWidth_Click" />
            <Button Grid.Column="2" x:Name="FitPageBtn" Content="适应页面"
                    Width="72" Height="28" FontSize="11" BorderThickness="0" Click="FitPage_Click" />

            <Border Grid.Column="3" />

            <Button Grid.Column="4" x:Name="PrevPageBtn" Content="◂"
                    Width="32" Height="28" FontSize="11" BorderThickness="0" Click="PrevPage_Click" />
            <TextBlock
                Grid.Column="5"
                x:Name="PageCounter"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                MinWidth="50"
                FontSize="11"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="1/1" />
            <Button Grid.Column="6" x:Name="NextPageBtn" Content="▸"
                    Width="32" Height="28" FontSize="11" BorderThickness="0" Click="NextPage_Click" />

            <Button Grid.Column="7" Content="关闭"
                    Width="56" Height="28" FontSize="11" BorderThickness="0" Click="Close_Click" />
        </Grid>
    </Grid>
</Window>
