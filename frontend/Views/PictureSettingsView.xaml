<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WordFormatterUI.Views.PictureSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WordFormatterUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Name="ViewRoot">

    <controls:ConfigCard Title="图片样式">
        <StackPanel Spacing="8">

            <!-- ════════ 图片尺寸 ════════ -->
            <Grid Height="32" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="图片尺寸" />
                <ComboBox
                    Grid.Column="1"
                    x:Name="SizeModeBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    SelectionChanged="SizeModeBox_SelectionChanged" />
            </Grid>

            <!-- 宽度输入（尺寸方式 = 指定宽度时显示） -->
            <Grid x:Name="WidthRow" Height="32" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="图片宽度" />
                <controls:NumericTextBox
                    Grid.Column="1"
                    x:Name="WidthBox"
                    Height="32"
                    ValueChanged="WidthBox_ValueChanged" />
                <ComboBox
                    Grid.Column="2"
                    x:Name="WidthUnitBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    SelectionChanged="WidthUnitBox_SelectionChanged" />
            </Grid>

            <!-- 高度输入（尺寸方式 = 指定高度时显示） -->
            <Grid x:Name="HeightRow" Height="32" ColumnSpacing="8" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="图片高度" />
                <controls:NumericTextBox
                    Grid.Column="1"
                    x:Name="HeightBox"
                    Height="32"
                    ValueChanged="HeightBox_ValueChanged" />
                <ComboBox
                    Grid.Column="2"
                    x:Name="HeightUnitBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    SelectionChanged="HeightUnitBox_SelectionChanged" />
            </Grid>

            <!-- 原始大小提示（尺寸方式 = 原始大小时显示） -->
            <Grid x:Name="AutoHintRow" Height="32" Visibility="Collapsed">
                <TextBlock
                    VerticalAlignment="Center"
                    Text="保持原始图片尺寸"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </Grid>

            <!-- ════════ 图片缩放 ════════ -->
            <Grid Height="32" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="图片缩放" />
                <CheckBox
                    Grid.Column="1"
                    x:Name="KeepAspectCheck"
                    Content="保持纵横比"
                    VerticalAlignment="Center"
                    Checked="KeepAspectCheck_Changed"
                    Unchecked="KeepAspectCheck_Changed" />
                <CheckBox
                    Grid.Column="2"
                    x:Name="NoEnlargeCheck"
                    Content="不放大图片"
                    VerticalAlignment="Center"
                    Checked="NoEnlargeCheck_Changed"
                    Unchecked="NoEnlargeCheck_Changed" />
            </Grid>

            <!-- ════════ 对齐方式 ════════ -->
            <Grid Height="32" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="对齐方式" />
                <ComboBox
                    Grid.Column="1"
                    x:Name="AlignmentBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    SelectionChanged="AlignmentBox_SelectionChanged" />
            </Grid>

            <!-- ════════ 文字环绕 ════════ -->
            <Grid Height="32" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="文字环绕" />
                <ComboBox
                    Grid.Column="1"
                    x:Name="WrappingStyleBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    SelectionChanged="WrappingStyleBox_SelectionChanged" />
            </Grid>

            <!-- ════════ 压缩质量 ════════ -->
            <Grid Height="32" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="压缩质量" />
                <controls:NumericTextBox
                    Grid.Column="1"
                    x:Name="QualityBox"
                    Height="32"
                    ValueChanged="QualityBox_ValueChanged" />
                <ComboBox
                    Grid.Column="2"
                    x:Name="QualityUnitBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    SelectionChanged="QualityUnitBox_SelectionChanged" />
            </Grid>

            <!-- ════════ 最大像素 ════════ -->
            <Grid Height="32" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="最大像素" />
                <controls:NumericTextBox
                    Grid.Column="1"
                    x:Name="MaxPixelsBox"
                    Height="32"
                    ValueChanged="MaxPixelsBox_ValueChanged" />
                <ComboBox
                    Grid.Column="2"
                    x:Name="MaxPixelsUnitBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    SelectionChanged="MaxPixelsUnitBox_SelectionChanged" />
            </Grid>

            <!-- ════════ 自动压缩大图片 ════════ -->
            <Grid Height="32" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="图片压缩" />
                <CheckBox
                    Grid.Column="1"
                    x:Name="AutoCompressCheck"
                    Content="自动压缩图片"
                    VerticalAlignment="Center"
                    Checked="AutoCompressCheck_Changed"
                    Unchecked="AutoCompressCheck_Changed" />
            </Grid>

        </StackPanel>
    </controls:ConfigCard>
</UserControl>