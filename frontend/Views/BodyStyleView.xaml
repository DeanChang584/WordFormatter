<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WordFormatterUI.Views.BodyStyleView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WordFormatterUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Name="ViewRoot">

    <!--
        BodyStyleView: body/paragraph formatting settings (design-document §9.3).
        Wrapped in ConfigCard with action buttons hidden (reset is global).
    -->
    <controls:ConfigCard Title="正文样式">
        <StackPanel Spacing="8">

            <!-- ── Font Settings ──────────────────────────────────────── -->

            <!-- 中文字体 -->
            <Grid Height="32" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="中文字体" />
                <ComboBox
                    Grid.Column="1"
                    x:Name="FontCnBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    SelectionChanged="FontCnBox_SelectionChanged" />
            </Grid>

            <!-- 西文字体 -->
            <Grid Height="32" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="西文字体" />
                <ComboBox
                    Grid.Column="1"
                    x:Name="FontEnBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    SelectionChanged="FontEnBox_SelectionChanged" />
            </Grid>

            <!-- 字号（中文名称下拉框：初号→小六） -->
            <Grid Height="32" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="字号" />
                <ComboBox
                    Grid.Column="1"
                    x:Name="FontSizeBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    SelectionChanged="FontSizeBox_SelectionChanged" />
            </Grid>

            <!-- 字形 (Font style: bold / italic / underline / strikethrough) -->
            <Grid Height="32" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="64" />
                    <ColumnDefinition Width="64" />
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="字形" />
                <CheckBox
                    Grid.Column="1"
                    x:Name="BoldCheck"
                    Content="加粗"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Stretch"
                    Checked="FontStyleCheck_Changed"
                    Unchecked="FontStyleCheck_Changed" />
                <CheckBox
                    Grid.Column="2"
                    x:Name="ItalicCheck"
                    Content="倾斜"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Stretch"
                    Checked="FontStyleCheck_Changed"
                    Unchecked="FontStyleCheck_Changed" />
                <CheckBox
                    Grid.Column="3"
                    x:Name="UnderlineCheck"
                    Content="下划线"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Stretch"
                    Checked="FontStyleCheck_Changed"
                    Unchecked="FontStyleCheck_Changed" />
                <CheckBox
                    Grid.Column="4"
                    x:Name="StrikethroughCheck"
                    Content="删除线"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Stretch"
                    Checked="FontStyleCheck_Changed"
                    Unchecked="FontStyleCheck_Changed" />
            </Grid>

            <!-- ── Paragraph Settings ──────────────────────────────────── -->

            <!-- 对齐方式 -->
            <Grid Height="32" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="对齐方式" />
                <ComboBox
                    Grid.Column="1"
                    x:Name="AlignmentBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    SelectionChanged="AlignmentBox_SelectionChanged" />
            </Grid>

            <!-- 行距模式 -->
            <Grid Height="32" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="行距" />
                <ComboBox
                    Grid.Column="1"
                    x:Name="LineSpacingModeBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    SelectionChanged="LineSpacingModeBox_SelectionChanged">
                    <ComboBoxItem Tag="multiple">单倍行距</ComboBoxItem>
                    <ComboBoxItem Tag="multiple">1.5 倍行距</ComboBoxItem>
                    <ComboBoxItem Tag="multiple">2 倍行距</ComboBoxItem>
                    <ComboBoxItem Tag="multiple">多倍行距</ComboBoxItem>
                    <ComboBoxItem Tag="fixed">固定值</ComboBoxItem>
                    <ComboBoxItem Tag="at_least">最小值</ComboBoxItem>
                </ComboBox>
                <controls:NumericTextBox
                    Grid.Column="2"
                    x:Name="LineSpacingValueBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    ValueChanged="LineSpacingValueBox_ValueChanged" />
                <ComboBox
                    Grid.Column="3"
                    x:Name="LineSpacingUnitBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    Visibility="Collapsed"
                    SelectionChanged="LineSpacingUnitBox_SelectionChanged">
                    <ComboBoxItem Tag="pt">磅</ComboBoxItem>
                    <ComboBoxItem Tag="cm">厘米</ComboBoxItem>
                    <ComboBoxItem Tag="mm">毫米</ComboBoxItem>
                </ComboBox>
            </Grid>

            <!-- 段前间距 -->
            <Grid Height="32" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="段前间距" />
                <controls:NumericTextBox
                    Grid.Column="1"
                    x:Name="SpaceBeforeBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    ValueChanged="SpaceBeforeBox_ValueChanged" />
                <ComboBox
                    Grid.Column="2"
                    x:Name="SpaceBeforeUnitBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    SelectedIndex="0"
                    SelectionChanged="SpaceBeforeUnitBox_SelectionChanged">
                    <ComboBoxItem>行</ComboBoxItem>
                    <ComboBoxItem>磅</ComboBoxItem>
                    <ComboBoxItem>厘米</ComboBoxItem>
                    <ComboBoxItem>毫米</ComboBoxItem>
                </ComboBox>
            </Grid>

            <!-- 段后间距 -->
            <Grid Height="32" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="段后间距" />
                <controls:NumericTextBox
                    Grid.Column="1"
                    x:Name="SpaceAfterBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    ValueChanged="SpaceAfterBox_ValueChanged" />
                <ComboBox
                    Grid.Column="2"
                    x:Name="SpaceAfterUnitBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    SelectedIndex="0"
                    SelectionChanged="SpaceAfterUnitBox_SelectionChanged">
                    <ComboBoxItem>行</ComboBoxItem>
                    <ComboBoxItem>磅</ComboBoxItem>
                    <ComboBoxItem>厘米</ComboBoxItem>
                    <ComboBoxItem>毫米</ComboBoxItem>
                </ComboBox>
            </Grid>

            <!-- 特殊格式（首行缩进 / 无缩进 / 悬挂缩进） -->
            <Grid Height="32" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="80" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="特殊格式" />
                <ComboBox
                    Grid.Column="1"
                    x:Name="BodySpecialIndentBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    SelectionChanged="BodySpecialIndentBox_SelectionChanged">
                    <ComboBoxItem Tag="firstLine">首行缩进</ComboBoxItem>
                    <ComboBoxItem Tag="none">无缩进</ComboBoxItem>
                    <ComboBoxItem Tag="hanging">悬挂缩进</ComboBoxItem>
                </ComboBox>
                <controls:NumericTextBox
                    Grid.Column="2"
                    x:Name="BodySpecialIndentValueBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    ValueChanged="BodySpecialIndentValueBox_ValueChanged" />
                <ComboBox
                    Grid.Column="3"
                    x:Name="BodySpecialIndentUnitBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    SelectionChanged="BodySpecialIndentUnitBox_SelectionChanged">
                    <ComboBoxItem>字符</ComboBoxItem>
                    <ComboBoxItem>磅</ComboBoxItem>
                    <ComboBoxItem>厘米</ComboBoxItem>
                    <ComboBoxItem>毫米</ComboBoxItem>
                </ComboBox>
            </Grid>

        </StackPanel>
    </controls:ConfigCard>
</UserControl>