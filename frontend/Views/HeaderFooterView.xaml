<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WordFormatterUI.Views.HeaderFooterView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WordFormatterUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Name="ViewRoot">

    <!--
        HeaderFooterView: page header & footer settings (design-document §9.2).
        Aligned with BodyStyleView layout conventions (ColumnSpacing=8, label width 72, control width 120).
    -->
    <controls:ConfigCard Title="页眉页脚">
        <StackPanel Spacing="8">

            <!-- 中文字体 -->
            <Grid Height="32" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="中文字体" />
                <ComboBox
                    Grid.Column="1"
                    x:Name="FontCnBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    SelectionChanged="FontCnBox_SelectionChanged" />
            </Grid>

            <!-- 西文字体 -->
            <Grid Height="32" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="西文字体" />
                <ComboBox
                    Grid.Column="1"
                    x:Name="FontEnBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    SelectionChanged="FontEnBox_SelectionChanged" />
            </Grid>

            <!-- 字号（中文名称下拉框：初号→小六，与正文样式一致） -->
            <Grid Height="32" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="字号" />
                <ComboBox
                    Grid.Column="1"
                    x:Name="FontSizeBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    SelectionChanged="FontSizeBox_SelectionChanged" />
            </Grid>

            <!-- 字形 (Font style: bold / italic / underline / strikethrough，与正文样式一致) -->
            <Grid Height="32" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="64" />
                    <ColumnDefinition Width="64" />
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="字形" />
                <CheckBox
                    Grid.Column="1"
                    x:Name="BoldCheck"
                    Content="加粗"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Stretch"
                    Checked="FontStyleCheck_Changed"
                    Unchecked="FontStyleCheck_Changed" />
                <CheckBox
                    Grid.Column="2"
                    x:Name="ItalicCheck"
                    Content="倾斜"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Stretch"
                    Checked="FontStyleCheck_Changed"
                    Unchecked="FontStyleCheck_Changed" />
                <CheckBox
                    Grid.Column="3"
                    x:Name="UnderlineCheck"
                    Content="下划线"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Stretch"
                    Checked="FontStyleCheck_Changed"
                    Unchecked="FontStyleCheck_Changed" />
                <CheckBox
                    Grid.Column="4"
                    x:Name="StrikethroughCheck"
                    Content="删除线"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Stretch"
                    Checked="FontStyleCheck_Changed"
                    Unchecked="FontStyleCheck_Changed" />
            </Grid>

            <!-- 对齐方式 -->
            <Grid Height="32" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="对齐方式" />
                <ComboBox
                    Grid.Column="1"
                    x:Name="AlignmentBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    SelectionChanged="AlignmentBox_SelectionChanged" />
            </Grid>

            <!-- 页眉距顶部距离（mm/cm 单位下拉选择） -->
            <Grid Height="32" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="页眉边距" />
                <controls:NumericTextBox
                    Grid.Column="1"
                    x:Name="HeaderDistBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    ValueChanged="HeaderDistBox_ValueChanged" />
                <ComboBox
                    Grid.Column="2"
                    x:Name="HeaderDistUnitBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    SelectedIndex="0"
                    SelectionChanged="HeaderDistUnitBox_SelectionChanged">
                    <ComboBoxItem>毫米</ComboBoxItem>
                    <ComboBoxItem>厘米</ComboBoxItem>
                </ComboBox>
            </Grid>

            <!-- 页脚距底部距离（mm/cm 单位下拉选择） -->
            <Grid Height="32" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="页脚边距" />
                <controls:NumericTextBox
                    Grid.Column="1"
                    x:Name="FooterDistBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    ValueChanged="FooterDistBox_ValueChanged" />
                <ComboBox
                    Grid.Column="2"
                    x:Name="FooterDistUnitBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    SelectedIndex="0"
                    SelectionChanged="FooterDistUnitBox_SelectionChanged">
                    <ComboBoxItem>毫米</ComboBoxItem>
                    <ComboBoxItem>厘米</ComboBoxItem>
                </ComboBox>
            </Grid>

        </StackPanel>
    </controls:ConfigCard>
</UserControl>