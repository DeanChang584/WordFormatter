<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WordFormatterUI.Views.AdvancedSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WordFormatterUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Name="ViewRoot">

    <!--
        AdvancedSettingsView: application-wide settings (design-document §17 / plan §7.7).
        Language, theme (bound to ThemeService), auto-check-update.
    -->
    <controls:ConfigCard Title="系统设置">
        <StackPanel Spacing="16">

            <!-- 界面语言 -->
            <Grid Height="32" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="界面语言" />
                <ComboBox
                    Grid.Column="1"
                    x:Name="LanguageBox"
                    Height="32"
                    HorizontalAlignment="Stretch">
                    <ComboBoxItem Tag="zh-CN">简体中文</ComboBoxItem>
                </ComboBox>
            </Grid>

            <!-- 主题设置 -->
            <Grid Height="32" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="主题设置" />
                <ComboBox
                    Grid.Column="1"
                    x:Name="ThemeBox"
                    Height="32"
                    HorizontalAlignment="Stretch"
                    SelectedIndex="0">
                    <ComboBoxItem Tag="light">浅色</ComboBoxItem>
                </ComboBox>
            </Grid>

        </StackPanel>
    </controls:ConfigCard>
</UserControl>
