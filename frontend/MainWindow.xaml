<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="WordFormatterUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WordFormatterUI.Controls"
    xmlns:views="using:WordFormatterUI.Views"
    xmlns:common="using:WordFormatterUI.Models.Common"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title=""
    mc:Ignorable="d">

    <Grid x:Name="LayoutRoot" Loaded="Page_Loaded" SizeChanged="LayoutRoot_SizeChanged" PointerPressed="LayoutRoot_PointerPressed" Padding="0,0,0,0">

        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <!-- Title Bar (custom, no software name label, icon only) -->
        <controls:TitleBar
            x:Name="TitleBarControl"
            Grid.Row="0" />

        <!-- Main Content: Three Columns -->
        <Grid
            x:Name="MainContentGrid"
            Grid.Row="1"
            Padding="16,0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ColLeft" Width="160" MinWidth="64" MaxWidth="360" />
                <ColumnDefinition x:Name="ColMid" Width="3.6*" MinWidth="440" />
                <ColumnDefinition x:Name="ColRight" Width="2.4*" MinWidth="300" />
            </Grid.ColumnDefinitions>

            <!-- Left Column: Navigation (custom NavBar with icons, keyboard, compact mode) -->
            <controls:NavBar
                x:Name="NavBarControl"
                Grid.Column="0"
                SelectionChanged="NavBarControl_SelectionChanged"
                CompactModeChanged="NavBarControl_CompactModeChanged" />

            <!-- TODO: Column resize splitter between left and middle columns (future step) -->
            <Border Grid.Column="0" HorizontalAlignment="Right" Width="1"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <!-- Middle Column: Configuration Form + Save Bar -->
            <Grid x:Name="MiddleColumnGrid" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
            <ScrollViewer
                x:Name="ConfigScroll"
                Grid.Row="0"
                VerticalScrollBarVisibility="Auto"
                Padding="16,0,8,0">
            <StackPanel Spacing="24" Margin="0,0,0,0">

                <!-- Page Settings Section (extracted to PageSettingsView) -->
                <views:PageSettingsView
                    x:Name="PageSettingsView"
                    DataContext="{x:Bind ViewModel.PageSettingsVm}" />

                <!-- Body Style Section (extracted to BodyStyleView) -->
                <views:BodyStyleView
                    x:Name="BodyStyleView"
                    Visibility="Collapsed"
                    DataContext="{x:Bind ViewModel.BodyStyleVm}" />

                <!-- Heading Style Section (extracted to HeadingStyleView) -->
                <views:HeadingStyleView
                    x:Name="HeadingStyleView"
                    Visibility="Collapsed"
                    DataContext="{x:Bind ViewModel.HeadingStyleVm}" />

                <!-- Header/Footer Section (extracted to HeaderFooterView) -->
                <views:HeaderFooterView
                    x:Name="HeaderFooterView"
                    Visibility="Collapsed"
                    DataContext="{x:Bind ViewModel.HeaderFooterVm}" />

                <!-- Image Settings Section (extracted to PictureSettingsView) -->
                <views:PictureSettingsView
                    x:Name="PictureSettingsView"
                    Visibility="Collapsed"
                    DataContext="{x:Bind ViewModel.PictureSettingsVm}" />

                <!-- Table Settings Section (extracted to TableSettingsView) -->
                <Grid x:Name="TableSettingsPlaceholder" Visibility="Collapsed" />

                <!-- Advanced Settings Section (extracted to AdvancedSettingsView) -->
                <views:AdvancedSettingsView
                    x:Name="AdvancedSettingsView"
                    Visibility="Collapsed" />

                <!-- About Section -->
                <views:AboutView
                    x:Name="AboutView"
                    Visibility="Collapsed" />

            </StackPanel>
            </ScrollViewer>

            <!-- Save Bar — fixed at bottom of config column, does not scroll -->
            <Grid x:Name="SaveBar" Grid.Row="1" Padding="16,8,16,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12"
                           Text="{x:Bind ViewModel.DirtyStatusText, Mode=OneWay}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="恢复默认"
                            Command="{x:Bind ViewModel.ResetProfileCommand}" />
                    <Button Content="保存配置" Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.SaveProfileCommand}"
                            IsEnabled="{x:Bind ViewModel.CanSave, Mode=OneWay}">
                        <Button.Resources>
                            <SolidColorBrush x:Key="AccentButtonBackgroundDisabled" Color="#D9D9D9" />
                            <SolidColorBrush x:Key="AccentButtonForegroundDisabled" Color="#A19F9D" />
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

            <!-- TODO: Column resize splitter between middle and right columns (future step) -->
            <Border x:Name="RightColumnDivider" Grid.Column="1" HorizontalAlignment="Right" Width="1"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <!-- Right Column: Files + Format (default) / 高级功能 (Advanced Settings) -->
            <Grid x:Name="RightColumnGrid" Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- ── Panel 1: File Management (default) ──────────────── -->
                <Grid x:Name="FileManagementPanel" Grid.Row="0" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ScrollViewer
                        x:Name="RightColumnContent"
                        Grid.Row="0"
                        VerticalScrollBarVisibility="Auto"
                        Padding="16,16,8,0">
                    <StackPanel>

                        <!-- File Management Card header: title + toolbar -->
                        <StackPanel Spacing="8">
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource SubtitleTextBlockStyle}" Text="文件管理" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" x:Name="SelectedCountText" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="已选 0 个文件" />
                            </Grid>

                            <!-- Toolbar: add file / add folder / recent -->
                            <Grid ColumnSpacing="8" Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" HorizontalAlignment="Stretch" Content="添加文档" Style="{StaticResource AccentButtonStyle}" Click="AddFiles_Click" />
                                <Button Grid.Column="1" HorizontalAlignment="Stretch" Content="添加文件夹" Click="AddFolder_Click" />
                                <DropDownButton Grid.Column="2" x:Name="RecentButton" ToolTipService.ToolTip="最近打开">
                                    <FontIcon Glyph="&#xE81C;" FontFamily="Segoe Fluent Icons" FontSize="14" />
                                    <DropDownButton.Flyout>
                                        <MenuFlyout x:Name="RecentFlyout" Placement="Bottom" Opening="RecentFlyout_Opening" />
                                    </DropDownButton.Flyout>
                                </DropDownButton>
                            </Grid>

                        </StackPanel>

                        <!-- File list (name / size / path), multi-select, drag-drop target -->
                        <Border MinHeight="200" MaxHeight="240" BorderThickness="2" BorderBrush="{ThemeResource FileListBorderBrush}" CornerRadius="4"
                                AllowDrop="True" DragOver="FileList_DragOver" Drop="FileList_Drop"
                                Margin="0,24,0,24">
                        <ListView
                            x:Name="FileListView"
                            SelectionMode="None">
                            <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="common:FileItemDto">
                                         <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                                   Checked="FileCheckBox_CheckedChanged"
                                                   Unchecked="FileCheckBox_CheckedChanged"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Stretch">
                                             <CheckBox.Resources>
                                                 <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillChecked" Color="#005FBA" />
                                                 <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillCheckedPointerOver" Color="#146CBF" />
                                                 <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillCheckedPressed" Color="#004A91" />
                                                 <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeChecked" Color="#005FBA" />
                                                 <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeCheckedPointerOver" Color="#146CBF" />
                                                 <SolidColorBrush x:Key="CheckBoxCheckBackgroundStrokeCheckedPressed" Color="#004A91" />
                                                 <SolidColorBrush x:Key="CheckBoxCheckGlyphForegroundChecked" Color="#FFFFFF" />
                                             </CheckBox.Resources>
                                             <CheckBox.Content>
                                                <Grid Margin="0,2" ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Spacing="0">
                                                        <TextBlock Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                                                        <TextBlock Text="{x:Bind Path}" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{x:Bind SizeText}" FontSize="11" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                </Grid>
                                            </CheckBox.Content>
                                        </CheckBox>
                                    </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        </Border>

                        <!-- Selection ops: select all / invert -->
                        <Grid ColumnSpacing="8" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" HorizontalAlignment="Stretch" x:Name="SelectAllBtn" Content="全选" Style="{StaticResource AccentButtonStyle}" IsEnabled="False" Click="SelectAll_Click">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="AccentButtonBackgroundDisabled" Color="#D9D9D9" />
                                    <SolidColorBrush x:Key="AccentButtonForegroundDisabled" Color="#A19F9D" />
                                </Button.Resources>
                            </Button>
                            <Button Grid.Column="1" HorizontalAlignment="Stretch" x:Name="InvertBtn" Content="反选" Style="{StaticResource AccentButtonStyle}" IsEnabled="False" Click="InvertSelection_Click">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="AccentButtonBackgroundDisabled" Color="#D9D9D9" />
                                    <SolidColorBrush x:Key="AccentButtonForegroundDisabled" Color="#A19F9D" />
                                </Button.Resources>
                            </Button>
                        </Grid>

                        <!-- Remove / clear ops — left-aligned with "文件管理" title (no extra padding) -->
                        <Grid ColumnSpacing="8" Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" HorizontalAlignment="Stretch" x:Name="RemoveBtn" Content="移除选中" IsEnabled="False" Click="RemoveSelected_Click" />
                            <Button Grid.Column="1" HorizontalAlignment="Stretch" x:Name="ClearBtn" Content="清空所有" IsEnabled="False" Click="ClearAll_Click" />
                        </Grid>

                        <!-- Unified card: ResultHistory + FormatControl (no separate borders) -->
                        <Border
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="0"
                            CornerRadius="8"
                            Padding="0,8,0,12"
                            Margin="0,8,0,0">
                            <StackPanel Spacing="8">
                                <views:ResultHistoryView
                                    x:Name="ResultHistoryView"
                                    DataContext="{x:Bind ViewModel.FormatVm}"
                                    RetrySingleFileRequested="ResultHistoryView_RetrySingleFileRequested"
                                    ReuseHistoryRequested="ResultHistoryView_ReuseHistoryRequested" />
                                <views:FormatControlView
                                    x:Name="FormatControlView"
                                    ShowActionButtons="False"
                                    DataContext="{x:Bind ViewModel.FormatVm}"
                                    PickOutputDirRequested="FormatControlView_PickOutputDirRequested"
                                    StartFormatRequested="FormatControlView_StartFormatRequested"
                                    PreviewRequested="FormatControlView_PreviewRequested"
                                    OpenResultRequested="FormatControlView_OpenResultRequested" />
                            </StackPanel>
                        </Border>

                    </StackPanel>
                    </ScrollViewer>

                    <!-- Action buttons bar — fixed at bottom, aligns with "保存配置" in middle column -->
                    <Border Grid.Row="1" Padding="16,8,8,8"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button
                                Grid.Column="0"
                                x:Name="RightPreviewBtn"
                                HorizontalAlignment="Stretch"
                                Content="预览效果"
                                Click="RightPreviewBtn_Click" />
                            <Button
                                Grid.Column="1"
                                x:Name="RightStartBtn"
                                HorizontalAlignment="Stretch"
                                Content="开始排版"
                                Style="{StaticResource AccentButtonStyle}"
                                Click="RightStartBtn_Click" />
                        </Grid>
                    </Border>
                </Grid>

                <!-- ── Panel 2: Advanced Functions (shown when navigating to Advanced Settings) ── -->
                <Grid
                    x:Name="AdvancedFunctionsPanel"
                    Grid.Row="0"
                    Visibility="Collapsed"
                    Padding="16,16,8,0">
                    <views:TemplateManagementView
                        x:Name="TemplateManagementView"
                        DataContext="{x:Bind ViewModel.TemplateManagementVm}" />
                </Grid>
            </Grid>
        </Grid>

        <!-- Status Bar (bound to MainViewModel via x:Bind) -->
        <controls:StatusBar
            x:Name="StatusBarControl"
            Grid.Row="2"
            StatusText="{x:Bind ViewModel.StatusText, Mode=OneWay}"
            FileCount="{x:Bind ViewModel.FileCountText, Mode=OneWay}"
            TemplateName="{x:Bind ViewModel.TemplateName, Mode=OneWay}"
            StateKind="{x:Bind ViewModel.StatusBarState, Mode=OneWay}"
            CurrentFile="{x:Bind ViewModel.ProgressText, Mode=OneWay}" />
    </Grid>
</Window>