<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WordFormatterUI.Controls.TitleBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Height="32">

    <!--
        Transparent background so the system Mica/Acrylic backdrop shows through.
        The entire Grid (except caption-buttons zone) is registered as drag region.
    -->
    <Grid x:Name="TitleBarGrid" Background="Transparent">

        <Grid.ColumnDefinitions>
            <!-- Left: app icon + spacer -->
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="16" />
            <!-- Center: page title -->
            <ColumnDefinition Width="*" />
            <!-- Right: caption buttons region (136px at 1x, auto-scales) -->
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Left: app icon -->
        <Border
            x:Name="IconBorder"
            Grid.Column="0"
            Width="32"
            Height="32"
            Background="Transparent">
            <Image
                x:Name="AppIcon"
                Source="ms-appx:///Assets/Logo.png"
                Width="20"
                Height="20"
                VerticalAlignment="Center"
                HorizontalAlignment="Center" />
        </Border>

        <!-- Right spacer: reserves space for system caption buttons -->
        <Border
            Grid.Column="3"
            Width="136"
            Height="32"
            x:Name="CaptionButtonsPlaceholder"
            Background="Transparent" />
    </Grid>
</UserControl>
