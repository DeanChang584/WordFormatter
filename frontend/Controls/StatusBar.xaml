<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WordFormatterUI.Controls.StatusBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Height="32"
    x:Name="StatusBarRoot">

    <!--
        StatusBar: bottom information strip.
        Height=32px, design-document §8.

        Layout:
          Col0: status dot + status text        (left, auto)
          Col1: template name                    (auto)
          Col2: spacer                           (*)
          Col3: file count + current file + version (right, auto)
    -->
    <Grid
        Background="{ThemeResource LayerFillColorDefaultBrush}"
        Padding="16,0">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Col 0: Status indicator + text -->
        <StackPanel
            Grid.Column="0"
            Orientation="Horizontal"
            Spacing="6"
            VerticalAlignment="Center"
            Margin="0,0,16,0">
            <Ellipse
                x:Name="StatusDot"
                Width="8"
                Height="8"
                Fill="{ThemeResource SystemAccentColor}" />
            <TextBlock
                x:Name="StatusTextBlock"
                Text="已就绪"
                FontSize="12"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- Col 1: Template name -->
        <TextBlock
            x:Name="TemplateNameBlock"
            Grid.Column="1"
            Text="默认模板"
            FontSize="12"
            VerticalAlignment="Center"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

        <!-- Col 3: Right-side info (file count, current file, version) -->
        <StackPanel
            Grid.Column="3"
            Orientation="Horizontal"
            Spacing="8"
            VerticalAlignment="Center">
            <TextBlock
                x:Name="FileCountBlock"
                FontSize="12"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock
                x:Name="CurrentFileBlock"
                FontSize="12"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock
                x:Name="VersionBlock"
                Text="Word Formatter 2.0"
                FontSize="12"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
        </StackPanel>
    </Grid>
</UserControl>