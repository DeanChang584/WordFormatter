  <property name="styleSheet">
   <string notr="true">
/* ============================================================
   Word 文档排版工具 — Apple-design-analysis 样式表
   忠实还原 Apple 官网设计语言
   ============================================================ */

/* --- 全局默认 --- */
* {
    font-family: "Segoe UI Variable Text", "Microsoft YaHei UI";
    font-size: 11pt;
    color: #1D1D1F;
}

/* --- Canvas: Parchment 底座 --- */
QMainWindow, QWidget#centralwidget {
    background-color: #F5F5F7;
}

/* --- 卡片 (QGroupBox): 纯白悬浮于 Parchment 之上 --- */
QGroupBox {
    font-family: "Segoe UI Variable Display", "Microsoft YaHei UI";
    font-size: 14pt;
    font-weight: 600;
    color: #1D1D1F;
    background-color: #FFFFFF;
    border: 1px solid rgba(0, 0, 0, 0.04);
    border-radius: 18px;
    padding-top: 40px;
    padding-left: 24px;
    padding-right: 24px;
    padding-bottom: 24px;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 24px;
    top: 14px;
}

/* --- 列表 --- */
QListWidget {
    background-color: #FFFFFF;
    border: 1px solid #E0E0E0;
    border-radius: 18px;
    padding: 4px;
    color: #1D1D1F;
}
QListWidget::item {
    border-radius: 4px;
    padding: 4px 8px;
}
QListWidget::item:hover {
    background-color: #F5F5F7;
}
QListWidget::item:selected {
    background-color: #E8F0FE;
    color: #1D1D1F;
}

/* --- 输入控件：干净简约 --- */
QLineEdit, QSpinBox, QDoubleSpinBox, QComboBox {
    background-color: #FFFFFF;
    color: #1D1D1F;
    border: 1px solid #E0E0E0;
    border-radius: 8px;
    padding: 6px 10px;
    min-height: 24px;
}
QLineEdit:hover, QSpinBox:hover, QDoubleSpinBox:hover, QComboBox:hover {
    border: 1px solid #0066CC;
}
QLineEdit:focus, QSpinBox:focus, QDoubleSpinBox:focus, QComboBox:focus {
    border: 1px solid #0066CC;
}

/* --- 下拉框 --- */
QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 20px;
    border-left-width: 0px;
}

/* --- 辅助按钮: ghost pill (透明底 + 蓝边框) --- */
QPushButton {
    background-color: transparent;
    color: #0066CC;
    border: 1px solid #0066CC;
    border-radius: 9999px;
    padding: 8px 16px;
}
QPushButton:hover {
    background-color: rgba(0, 102, 204, 0.04);
}
QPushButton:pressed {
    background-color: rgba(0, 102, 204, 0.08);
}

/* --- 主行动按钮 [▶ 开始排版]: 实心蓝色胶囊 --- */
QPushButton#btn_start_format {
    background-color: #0066CC;
    color: #FFFFFF;
    border: none;
    font-family: "Segoe UI Variable Display", "Microsoft YaHei UI";
    font-size: 13pt;
    font-weight: 600;
    border-radius: 9999px;
    padding: 11px 24px;
}
QPushButton#btn_start_format:hover {
    background-color: #0071E3;
}
QPushButton#btn_start_format:pressed {
    background-color: #0055AA;
}

/* --- 勾选框 --- */
QCheckBox {
    color: #1D1D1F;
    spacing: 6px;
}

/* --- 进度条 --- */
QProgressBar {
    background-color: #E8E8ED;
    border: none;
    border-radius: 4px;
    min-height: 6px;
    text-align: center;
    font-size: 9pt;
    font-weight: 400;
    color: #1D1D1F;
}
QProgressBar::chunk {
    background-color: #0066CC;
    border-radius: 4px;
}

/* --- 滚动区域: 透明融入底座 --- */
QScrollArea {
    background-color: transparent;
    border: none;
}

/* --- 滚动条: 极简 --- */
QScrollBar:vertical {
    background-color: transparent;
    width: 6px;
    margin: 0;
}
QScrollBar::handle:vertical {
    background-color: rgba(0, 0, 0, 0.15);
    border-radius: 3px;
    min-height: 30px;
}
QScrollBar::handle:vertical:hover {
    background-color: rgba(0, 0, 0, 0.25);
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px;
}

/* --- 状态栏 --- */
QLabel#label_status {
    background-color: #FFFFFF;
    border: 1px solid rgba(0, 0, 0, 0.04);
    border-radius: 18px;
    font-family: "Segoe UI Variable Text", "Microsoft YaHei UI";
    font-size: 10pt;
    font-weight: 400;
    color: #6E6E73;
}

/* --- 页面标题 --- */
QLabel#label_title {
    font-family: "Segoe UI Variable Display", "Microsoft YaHei UI";
    font-size: 28pt;
    font-weight: 600;
    color: #1D1D1F;
    background-color: transparent;
}

/* --- 分隔条: 隐形 --- */
QSplitter::handle {
    background-color: transparent;
}
   </string>
